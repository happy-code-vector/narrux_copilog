# aiTrate Agent — Environment Variables
# Copy to .env and fill in values

# ─── Anthropic API ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_OPUS=claude-opus-4-8

# ─── Voyage AI (embeddings + reranker) ──────────────────────
VOYAGE_API_KEY=pa-xxx
VOYAGE_EMBEDDING_MODEL=voyage-3-large
VOYAGE_RERANKER_MODEL=rerank-2

# ─── PostgreSQL (trade DB + pgvector + audit log) ───────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aitrate
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/aitrate

# ─── Redis (cache + background jobs) ────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Langfuse (LLM observability) ───────────────────────────
LANGFUSE_PUBLIC_KEY=pk-xxx
LANGFUSE_SECRET_KEY=sk-xxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ─── Agent Settings ─────────────────────────────────────────
# Max tokens for LLM responses
AGENT_MAX_TOKENS=4096
# Temperature for routine queries (lower = more deterministic)
AGENT_TEMPERATURE_ROUTINE=0.1
# Temperature for recommendation generation
AGENT_TEMPERATURE_RECOMMENDATION=0.3
# Enable response streaming
AGENT_STREAMING=true

# ─── Retrieval Settings ─────────────────────────────────────
# Number of chunks to retrieve from vector store
RETRIEVAL_TOP_K=50
# Number of chunks after reranking
RETRIEVAL_TOP_N=10
# Chunk size for document ingestion
RETRIEVAL_CHUNK_SIZE=1000
# Chunk overlap
RETRIEVAL_CHUNK_OVERLAP=200

# ─── Eval Settings ──────────────────────────────────────────
# Minimum retrieval recall@5 to pass eval
EVAL_MIN_RECALL_AT_5=0.9
# Minimum faithfulness score
EVAL_MIN_FAITHFULNESS=0.85

# ─── Environment ────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
