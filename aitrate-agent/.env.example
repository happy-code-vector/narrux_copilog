# NARRUX aiTrate Co-Pilot — Environment Variables
# Copy to .env and fill in values

# ─── Qdrant (vector store) ──────────────────────────────────
# Mode: 'server' (Docker) or 'embedded' (local)
QDRANT_MODE=server
QDRANT_URL=http://localhost:6333
QDRANT_PATH=./qdrant_data
QDRANT_COLLECTION=kb_chunks

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL_PRIMARY=claude-opus-4-7
ANTHROPIC_MODEL_SECONDARY=claude-sonnet-4-6

# ─── Voyage AI ──────────────────────────────────────────────
VOYAGE_API_KEY=pa-xxx
VOYAGE_EMBEDDING_MODEL=voyage-3-large
VOYAGE_RERANK_MODEL=rerank-2

# ─── Langfuse ───────────────────────────────────────────────
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-xxx
LANGFUSE_SECRET_KEY=sk-xxx

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ─── Retrieval ──────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
MIN_RERANK_SCORE=0.3

# ─── Ingestion ──────────────────────────────────────────────
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=80

# ─── Agent ──────────────────────────────────────────────────
DAILY_TOKEN_CAP_PER_USER=100000
MAX_TOKENS_PER_RESPONSE=4096

# ─── Environment ────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
